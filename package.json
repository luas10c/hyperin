{
  "name": "hyperin",
  "description": "🚀 Fast, safe and modern",
  "keywords": [
    "nodejs",
    "fast",
    "performance",
    "secure"
  ],
  "version": "0.0.1-beta.10",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "types": "./dist/instance.d.ts",
  "exports": {
    ".": {
      "default": "./dist/instance.js",
      "import": "./dist/instance.js",
      "types": "./dist/instance.d.ts"
    },
    "./middleware": {
      "default": "./dist/middleware/index.js",
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./openapi": {
      "default": "./dist/openapi.js",
      "import": "./dist/openapi.js",
      "types": "./dist/openapi.d.ts"
    },
    "./logger": {
      "default": "./dist/logger.js",
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./scalar": {
      "default": "./dist/scalar.js",
      "import": "./dist/scalar.js",
      "types": "./dist/scalar.d.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.json --emitDeclarationOnly --removeComments false",
    "postbuild": "tsc-alias -f -p tsconfig.build.json",
    "lint": "eslint --cache",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:watchAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "author": {
    "name": "Luciano Alves",
    "url": "https://github.com/luas10c"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luas10c/hyperin.git"
  },
  "bugs": {
    "url": "https://github.com/luas10c/hyperin/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "license": "MIT"
}
